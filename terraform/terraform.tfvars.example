# terraform.tfvars.example
#
# Copy this to terraform.tfvars (which should be gitignored) and fill in real
# values, OR export them as environment variables instead:
#
#   export TF_VAR_proxmox_endpoint="https://pve.lan:8006/"
#   export TF_VAR_proxmox_api_token="terraform@pve!tf=xxxxxxxx-...-xxxxxxxx"
#
# Anything marked sensitive should prefer the env-var route so it never lands
# in a file on disk.

proxmox_endpoint  = "https://pve.lan:8006/"
proxmox_api_token = "terraform@pve!tf=00000000-0000-0000-0000-000000000000"
proxmox_node      = "pve"

template_vm_id = 9000

ci_user = "ansible"
ci_ssh_public_keys = [
  "ssh-ed25519 AAAA... you@workstation",
]

subnet_prefix = "192.168.1"
gateway       = "192.168.1.1"

# Override the default VM set if you like:
# vms = {
#   docker = { vmid = 110, cores = 4, memory = 8192, disk = 40, ip = "110", tags = ["services","docker"] }
# }

